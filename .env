# Server
PORT=3000
NODE_ENV=development

# Telegram Bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=8719625112:AAHBE27MZa2Di02WEqBjETxWgBQqR46At60
# Public HTTPS URL of this server, used by the bot's "Play" button (Telegram requires HTTPS)
WEBAPP_URL=https://your-deployed-domain.example.com
# Path Telegram will POST updates to (full webhook URL = WEBAPP_URL + this path)
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
# Random secret Telegram echoes back in a header on every webhook call, so you can verify
# a request actually came from Telegram and not a random POST to a guessed URL.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TELEGRAM_WEBHOOK_SECRET=change-this-to-a-random-string

# JWT
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Admin dashboard (src/public/admin.html)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
ADMIN_JWT_EXPIRES_IN=12h

# Database
DB_PATH=./src/database/bingo.db

# Game defaults
DEFAULT_GAME_SPEED_MS=5000
HOUSE_COMMISSION_PERCENT=10
